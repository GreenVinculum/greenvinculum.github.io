---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HorizontalCard from "../../components/HorizontalCard.astro";
---

<BaseLayout title="Research Portfolio" sideBarActiveItemID="portfolioResearch">
  <div class="space-y-4 mb-5">
    <div class="text-3xl w-full font-bold">Research Projects</div>
  </div>

  <div class="mt-5">
    <HorizontalCard
      title="Teleoperated 360 Video Capture of Beehives for Scientific Visualization in VR"
      img="/portfolio/research-projects/vrst25beevr/assets/images/teasruser.webp"
      desc="Framework for capturing and analyzing bee activity with commercial 360 cameras and immersive VR replay."
      url="/portfolio/research-projects/vrst25beevr/index.html"
      badge="NEW"
    />
    <div class="divider my-0"></div>
    <HorizontalCard
      title="Social XR Interface Study"
      img="/post_img.webp"
      desc="Comparative study of interaction methods for synchronous collaboration in XR."
      url="#"
    />
    <div class="divider my-0"></div>
    <HorizontalCard
      title="Human-Robot Teaming Prototype"
      img="/post_img.webp"
      desc="Interactive prototype exploring role negotiation between humans and assistive robots."
      url="#"
    />
  </div>
</BaseLayout>
