---
import BaseLayout from "../layouts/BaseLayout.astro";
import { UNIVERSE_GAMES } from "../data/universe-games";
---

<BaseLayout
  title="Universe ████████████"
  description="A hidden arcade between timelines."
  includeSidebar={false}
  noindex={true}
  sideBarActiveItemID=""
>
  <div class="universe-page universe-page--enter pb-12">
    <p class="text-xs uppercase tracking-[0.35em] opacity-50">Signal lock acquired</p>
    <p class="universe-page__welcome text-sm md:text-base uppercase tracking-[0.28em] text-primary/80">
      Welcome to the pocket dimension
    </p>
    <h1 class="text-4xl md:text-5xl font-bold leading-tight">
      Universe <span class="universe-page__redact" aria-hidden="true">████████████</span>
    </h1>
    <p class="text-lg max-w-prose opacity-80">
      Retro cabinets drift in the static. Choose a cartridge when the feed stabilizes.
    </p>

    <div class="universe-gallery mt-10" role="list" aria-label="Game gallery">
      {
        UNIVERSE_GAMES.map((game) => (
          <article class="universe-cartridge" role="listitem" data-available={game.available}>
            {game.available && game.href ? (
              <a class="universe-cartridge__link" href={game.href}>
                <div class="universe-cartridge__screen" aria-hidden="true">
                  <span class="universe-cartridge__glyph">{game.title.slice(0, 1)}</span>
                </div>
                <div class="universe-cartridge__meta">
                  <h2 class="universe-cartridge__title">{game.title}</h2>
                  <p class="universe-cartridge__tagline">{game.tagline}</p>
                  {game.decade && <p class="universe-cartridge__year">{game.decade}</p>}
                </div>
              </a>
            ) : (
              <div class="universe-cartridge__link universe-cartridge__link--soon">
                <div class="universe-cartridge__screen" aria-hidden="true">
                  <span class="universe-cartridge__glyph">{game.title.slice(0, 1)}</span>
                </div>
                <div class="universe-cartridge__meta">
                  <h2 class="universe-cartridge__title">{game.title}</h2>
                  <p class="universe-cartridge__tagline">{game.tagline}</p>
                  <p class="universe-cartridge__status">Coming soon</p>
                </div>
              </div>
            )}
          </article>
        ))
      }
    </div>

    <a class="btn btn-ghost btn-sm mt-10" href="/">← Return to reality</a>
  </div>
</BaseLayout>

<script>
  if (sessionStorage.getItem("wormhole-arrival") === "1") {
    sessionStorage.removeItem("wormhole-arrival");
    document.querySelector(".universe-page")?.classList.add("is-wormhole-in");
  }
</script>

<style>
  .universe-page__redact {
    display: inline-block;
    color: hsl(var(--er));
    letter-spacing: 0.1em;
    font-variant-numeric: tabular-nums;
  }

  .universe-page__welcome {
    margin-top: 0.35rem;
    margin-bottom: 0.85rem;
    font-weight: 600;
  }

  .universe-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(11.5rem, 1fr));
    gap: 1.25rem;
  }

  .universe-cartridge__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 0.85rem;
    border-radius: 0.65rem;
    border: 1px solid hsl(var(--bc) / 0.18);
    background: linear-gradient(165deg, hsl(var(--b2) / 0.9), hsl(var(--b3) / 0.55));
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .universe-cartridge__link--soon {
    opacity: 0.72;
    cursor: default;
  }

  .universe-cartridge[data-available="true"] .universe-cartridge__link:hover {
    transform: translateY(-3px);
    border-color: hsl(var(--p) / 0.45);
    box-shadow: 0 10px 28px hsl(var(--bc) / 0.12);
  }

  .universe-cartridge__screen {
    aspect-ratio: 4 / 3;
    border-radius: 0.4rem;
    margin-bottom: 0.75rem;
    background:
      radial-gradient(circle at 50% 35%, hsl(var(--p) / 0.35), transparent 58%),
      linear-gradient(180deg, hsl(var(--n) / 0.25), hsl(var(--b1)));
    border: 1px solid hsl(var(--bc) / 0.12);
    display: grid;
    place-items: center;
  }

  .universe-cartridge__glyph {
    font-size: 2.25rem;
    font-weight: 800;
    opacity: 0.55;
    font-family: ui-monospace, monospace;
  }

  .universe-cartridge__title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .universe-cartridge__tagline {
    margin-top: 0.25rem;
    font-size: 0.82rem;
    opacity: 0.7;
    line-height: 1.35;
  }

  .universe-cartridge__year,
  .universe-cartridge__status {
    margin-top: 0.45rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    opacity: 0.55;
  }

  .universe-page--enter {
    opacity: 0;
    transform: scale(1.04);
    filter: blur(6px);
    animation: universe-fade-in 1.1s ease forwards;
  }

  .universe-page.is-wormhole-in {
    animation: universe-wormhole-in 1.25s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes universe-fade-in {
    to {
      opacity: 1;
      transform: scale(1);
      filter: blur(0);
    }
  }

  @keyframes universe-wormhole-in {
    0% {
      opacity: 0;
      transform: scale(0.35);
      filter: blur(18px) brightness(2);
    }
    45% {
      opacity: 0.85;
      filter: blur(4px) brightness(1.2);
    }
    100% {
      opacity: 1;
      transform: scale(1);
      filter: blur(0) brightness(1);
    }
  }
</style>
