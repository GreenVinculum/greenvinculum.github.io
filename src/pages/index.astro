---
import BaseLayout from "../layouts/BaseLayout.astro";
import NerveTimeline from "../components/NerveTimeline.astro";
const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Charles Ahn",
  url: "https://greenvinculum.github.io/",
  jobTitle: "PhD Student in Computer Science",
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "George Mason University"
  },
  sameAs: [
    "https://twitter.com/"
  ]
};
---

<BaseLayout sideBarActiveItemID="home" jsonLd={personJsonLd}>
  <div class="pb-12 mt-5">
    <div class="landing-photo-block">
      <div
        class="wireframe-portrait"
        id="wireframePortrait"
        data-source="/images/profile"
        data-light-portrait="/images/profile-inverted"
        data-mesh-url="/data/wireframe-mesh.json"
        data-mesh-bin-url="/data/wireframe-mesh.pck.gz"
        data-loop-url="/media/wireframe-loop.webm"
        data-poster-url="/media/wireframe-poster.png"
        aria-label="Wireframe profile portrait"
      >
        <img
          id="wireframePoster"
          class="wireframe-poster"
          src="/media/wireframe-poster.png"
          alt=""
          width="760"
          height="1080"
          decoding="async"
          fetchpriority="high"
        />
        <img
          id="wireframeLightPortrait"
          class="wireframe-light-portrait hidden"
          alt=""
          width="760"
          height="1080"
          decoding="async"
        />
        <video
          id="wireframeLoop"
          class="wireframe-loop hidden"
          width="760"
          height="1080"
          muted
          loop
          playsinline
          preload="none"
        ></video>
        <canvas id="wireframeCanvas" class="wireframe-canvas-live hidden" width="760" height="1080"></canvas>
        <p id="wireframeFallback" class="wireframe-fallback hidden">
          Add your portrait to <code>/public/images/profile.png</code> or <code>/public/images/profile.jpg</code>
        </p>
      </div>
    </div>
    <div class="text-xl py-1">Hey there</div>
    <div class="font-bold leading-tight">
      <span class="text-3xl md:text-4xl text-base-content align-middle">I'm </span>
      <span class="glitch-name-wrap align-middle">
      <span class="glitch-name hero-name align-middle" data-text="Charles Ahn">
        <span class="glitch-char glitch-char-delay-c" data-char="C" style="--char-i:0">C</span><span class="glitch-char glitch-char-delay-h glitch-char-aggressive" data-char="h" style="--char-i:1">h<span aria-hidden="true" class="glitch-char-third">h</span></span><span class="glitch-char" data-char="a" style="--char-i:2">a</span><span class="glitch-char glitch-char-aggressive" data-char="r" style="--char-i:3">r<span aria-hidden="true" class="glitch-char-third">r</span></span><span class="glitch-char" data-char="l" style="--char-i:4">l</span><span class="glitch-char" data-char="e" style="--char-i:5">e</span><span class="glitch-char" data-char="s" style="--char-i:6">s</span><span class="glitch-char" data-char=" " style="--char-i:7">&nbsp;</span><span class="glitch-char glitch-char-survivor-a" data-char="A" style="--char-i:8">A</span><span class="glitch-char glitch-char-aggressive" data-char="h" style="--char-i:9">h<span aria-hidden="true" class="glitch-char-third">h</span></span><span class="glitch-char glitch-char-delay-n" data-char="n" style="--char-i:10">n</span>
        <span aria-hidden="true" class="glitch-tape-smear">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-pixel-noise">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-static-lines">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-vhs-scanlines">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-film-grain">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-film-dirt">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-static-run glitch-static-run-a">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-static-run glitch-static-run-b">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-static-run glitch-static-run-dark glitch-static-run-dark-a">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-static-run glitch-static-run-dark glitch-static-run-dark-b">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-name-ghost">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-name-ghost glitch-name-ghost-2">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-name-ghost glitch-name-ghost-3">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-name-rgb-a">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-name-rgb-b">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-name-slice glitch-name-slice-a">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-name-slice glitch-name-slice-b">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-name-slice glitch-name-slice-c">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-name-slice glitch-name-slice-d">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-name-shadow">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-name-line glitch-name-line-a">Charles Ahn</span>
        <span aria-hidden="true" class="glitch-name-line glitch-name-line-b">Charles Ahn</span>
      </span>
      </span>
    </div>
    <div class="text-3xl py-3 font-bold">PhD Student in Computer Science and a Tinkerer</div>
    <div class="py-2">
      <text class="text-lg">
        <p>I'm a first year PhD student in Computer Science at George Mason University. My research sits at the intersection between people and computing. That means whether I'm exploring new interaction paradigms, studying the complex interfaces between human and robot partnership, or finding ways to make technology more accessible to everyone. 
        
        <p>Over the past four years, I've had the opportunity to work with <a href="https://craigyuyu.github.io/home/index.html" target="_blank" rel="noopener noreferrer" class="inline-link-highlight"><b>Prof. Craig Yu</b></a> at the <a href="https://craigyuyu.github.io/home/group.html" target="_blank" rel="noopener noreferrer" class="inline-link-highlight"><strong>Design Computing and Extended Reality Group (DCXR)</strong></a>, where I've embraced just about everything that's come my way. From designing 3D and VR experiences in Unity, to engineering mechanical parts and bringing them to life with 3D printing, to implementing IoT devices to be deployed in the field. My work lives at the crossroads of the digital and the physical. 

        <p>Outside the lab, you can find me camping on Shenandoah mountain range, fishing and swimming, reading, as well as playing video games on my Steam Deck and Switch. I'm always happy to chat about research, design and cutting edge technologies, or anything in between really. So don't hesitate to reach out! 
        
      </text>
    </div>
    <div class="mt-8">
      <a class="btn" href="https://twitter.com/ " target="_blank"> Let's connect!</a>
    </div>
  </div>

  <section class="mt-4">
    <h2 class="text-2xl font-bold mb-3">News</h2>
    <NerveTimeline idPrefix="newsTimeline" syncGlitch={true}>
      <article class="news-item timeline-reveal is-faded">
        <div class="news-node" aria-hidden="true"></div>
        <div class="news-item__body">
          <p class="text-xs uppercase tracking-wide opacity-70">May 2026</p>
          <p>Rolled out portfolio redesign with structured schema metadata and timeline enhancements.</p>
        </div>
      </article>
      <article class="news-item timeline-reveal is-faded">
        <div class="news-node" aria-hidden="true"></div>
        <div class="news-item__body">
          <p class="text-xs uppercase tracking-wide opacity-70">Jan 2026</p>
          <p>Joined DCXR Lab at George Mason University and started PhD research full-time.</p>
        </div>
      </article>
      <article class="news-item timeline-reveal is-faded">
        <div class="news-node" aria-hidden="true"></div>
        <div class="news-item__body">
          <p class="text-xs uppercase tracking-wide opacity-70">Nov 2025</p>
          <p>Attended VRST 2025 and presented research on teleoperated 360 video capture of beehives for scientific visualization in VR.</p>
        </div>
      </article>
      <article class="news-item timeline-reveal is-faded">
        <div class="news-node" aria-hidden="true"></div>
        <div class="news-item__body">
          <p class="text-xs uppercase tracking-wide opacity-70">May 2025</p>
          <p>Completed B.S. in Computer Science while continuing immersive systems projects.</p>
        </div>
      </article>
    </NerveTimeline>
  </section>

  <section class="visit-widget mt-8">
    <h2 class="text-xl font-bold mb-2">Site Activity</h2>
    <p class="opacity-80">Total visits from this browser: <span id="visitCountValue">-</span></p>
    <p class="opacity-70 text-sm">Last visit: <span id="visitLastValue">First time visitor</span></p>
  </section>

  <script is:inline>
    const countEl = document.getElementById("visitCountValue");
    const lastEl = document.getElementById("visitLastValue");
    const countKey = "siteVisitCount";
    const lastKey = "siteVisitLastAt";
    const previousLastVisit = localStorage.getItem(lastKey);
    const count = Number(localStorage.getItem(countKey) || "0") + 1;

    localStorage.setItem(countKey, String(count));
    localStorage.setItem(lastKey, new Date().toISOString());

    if (countEl) countEl.textContent = String(count);
    if (lastEl && previousLastVisit) {
      const date = new Date(previousLastVisit);
      lastEl.textContent = date.toLocaleString();
    }

    const glitchWrap = document.querySelector(".glitch-name-wrap");
    if (glitchWrap) {
      const glitchChars = Array.from(document.querySelectorAll(".glitch-char"));
      const glowEligibleChars = glitchChars.filter((charEl) => charEl.dataset.char !== " ");
      const staticRuns = Array.from(document.querySelectorAll(".glitch-static-run"));
      const randomSigned = (min, max) => {
        const value = min + Math.random() * (max - min);
        return (Math.random() > 0.5 ? 1 : -1) * value;
      };
      const randomInt = (min, max) => Math.floor(min + Math.random() * (max - min + 1));

      const schedulePullShift = () => {
        glitchWrap.style.setProperty("--pull-a", `${randomSigned(10, 20).toFixed(1)}px`);
        glitchWrap.style.setProperty("--pull-b", `${randomSigned(10, 20).toFixed(1)}px`);
        glitchWrap.style.setProperty("--pull-c", `${randomSigned(12, 22).toFixed(1)}px`);
        glitchWrap.style.setProperty("--pull-d", `${randomSigned(12, 22).toFixed(1)}px`);
        glitchWrap.style.setProperty("--pull-char-a", `${randomSigned(0.5, 1.1).toFixed(2)}ch`);
        glitchWrap.style.setProperty("--pull-char-b", `${randomSigned(0.5, 1.1).toFixed(2)}ch`);

        glitchChars.forEach((charEl) => {
          const outRange = [8, 20];
          const jumbleRange = [0.4, 0.95];
          const stretchRange = [1.01, 1.1];
          charEl.style.setProperty("--char-out-x", `${randomSigned(outRange[0], outRange[1]).toFixed(1)}px`);
          charEl.style.setProperty("--char-jumble-x", `${randomSigned(jumbleRange[0], jumbleRange[1]).toFixed(2)}ch`);
          charEl.style.setProperty("--char-stretch", `${(stretchRange[0] + Math.random() * (stretchRange[1] - stretchRange[0])).toFixed(2)}`);
          charEl.style.setProperty("--letter-pull-top", `${randomSigned(1, 5).toFixed(1)}px`);
          charEl.style.setProperty("--letter-pull-bottom", `${randomSigned(1, 5).toFixed(1)}px`);
        });

        const nextPullMs = 1400 + Math.random() * 2800;
        setTimeout(schedulePullShift, nextPullMs);
      };

      const scheduleSpeedShift = () => {
        const nextSpeed = 4.5 + Math.random() * 2.5;
        glitchWrap.style.setProperty("--glitch-speed", `${nextSpeed.toFixed(2)}s`);
        const nextShiftMs = Math.max(2800, nextSpeed * 1000 + Math.random() * 1200);
        setTimeout(scheduleSpeedShift, nextShiftMs);
      };

      const scheduleLetterGlowPulse = () => {
        const pulseCount = Math.min(glowEligibleChars.length, randomInt(2, 4));
        const chosen = [...glowEligibleChars]
          .sort(() => Math.random() - 0.5)
          .slice(0, pulseCount);

        chosen.forEach((charEl, idx) => {
          const phaseOffset = idx * randomInt(35, 80);
          setTimeout(() => {
            charEl.classList.add("is-glow-up");
            setTimeout(() => {
              charEl.classList.remove("is-glow-up");
              charEl.classList.add("is-glow-dim");
              setTimeout(() => {
                charEl.classList.remove("is-glow-dim");
              }, randomInt(130, 190));
            }, randomInt(170, 250));
          }, phaseOffset);
        });

        const nextGlowMs = 1900 + Math.random() * 3300;
        setTimeout(scheduleLetterGlowPulse, nextGlowMs);
      };

      const triggerStaticRun = (runEl) => {
        const top = randomInt(8, 80);
        const isDarkRun = runEl.classList.contains("glitch-static-run-dark");
        let thickness = isDarkRun ? randomInt(7, 14) : randomInt(3, 8);
        let durationMin = isDarkRun ? 220 : 180;
        let durationMax = isDarkRun ? 420 : 320;
        const modeRoll = Math.random();
        let modeClass = "is-mode-normal";

        if (isDarkRun) {
          if (modeRoll < 0.33) {
            thickness = randomInt(12, 20);
            durationMin = 260;
            durationMax = 480;
            modeClass = "is-mode-heavy";
          } else if (modeRoll < 0.66) {
            thickness = randomInt(9, 16);
            durationMin = 120;
            durationMax = 230;
            modeClass = "is-mode-hardcut";
          }
        }

        const bottom = Math.max(0, 100 - top - thickness);
        runEl.style.setProperty("--static-top", `${top}%`);
        runEl.style.setProperty("--static-bottom", `${bottom}%`);
        runEl.style.setProperty("--static-shift", `${randomSigned(isDarkRun ? 0.5 : 0.4, isDarkRun ? 2.4 : 1.8).toFixed(2)}px`);
        runEl.classList.remove("is-mode-normal", "is-mode-heavy", "is-mode-hardcut");
        runEl.classList.add(modeClass);
        runEl.classList.add("is-active");
        setTimeout(() => {
          runEl.classList.remove("is-active");
          runEl.classList.remove("is-mode-normal", "is-mode-heavy", "is-mode-hardcut");
        }, randomInt(durationMin, durationMax));
      };

      const scheduleStaticSweep = () => {
        if (staticRuns.length > 0) {
          triggerStaticRun(staticRuns[randomInt(0, staticRuns.length - 1)]);
          if (Math.random() < 0.82) {
            setTimeout(() => {
              triggerStaticRun(staticRuns[randomInt(0, staticRuns.length - 1)]);
            }, randomInt(70, 170));
          }
          if (Math.random() < 0.55) {
            setTimeout(() => {
              triggerStaticRun(staticRuns[randomInt(0, staticRuns.length - 1)]);
            }, randomInt(190, 320));
          }
          if (Math.random() < 0.38) {
            const darkRuns = staticRuns.filter((run) => run.classList.contains("glitch-static-run-dark"));
            if (darkRuns.length > 0) {
              setTimeout(() => {
                triggerStaticRun(darkRuns[randomInt(0, darkRuns.length - 1)]);
              }, randomInt(90, 260));
            }
          }
        }

        const nextStaticMs = 120 + Math.random() * 520;
        setTimeout(scheduleStaticSweep, nextStaticMs);
      };

      const scheduleRandomDrop = () => {
        const waitMs = 5200 + Math.random() * 9000;
        setTimeout(() => {
          const visibleChars = glitchChars.filter((charEl) => charEl.dataset.char !== " ");
          const dropRoll = Math.random();
          const offMs = 54 + Math.random() * 72;
          const clearDropClasses = () => {
            glitchWrap.classList.remove("is-full-off");
            glitchWrap.classList.remove("is-random-off");
            glitchWrap.classList.remove("is-partial-drop");
            glitchChars.forEach((charEl) => charEl.classList.remove("is-drop-off"));
          };

          const applyRecoveryShift = () => {
            const recoverClass = Math.random() < 0.5 ? "is-recover-dim" : "is-recover-bright";
            glitchWrap.classList.add(recoverClass);
            setTimeout(() => glitchWrap.classList.remove(recoverClass), 380 + Math.random() * 260);
          };

          if (dropRoll < 0.08) {
            glitchWrap.classList.add("is-random-off", "is-full-off");
          } else {
            let dropCount = 2;
            if (dropRoll < 0.45) {
              dropCount = Math.min(visibleChars.length, randomInt(1, 2));
            } else if (dropRoll < 0.8) {
              dropCount = Math.min(visibleChars.length, randomInt(3, 4));
            } else {
              dropCount = Math.min(visibleChars.length, randomInt(5, 6));
            }
            glitchWrap.classList.add("is-partial-drop");
            const picked = [...visibleChars].sort(() => Math.random() - 0.5).slice(0, dropCount);
            picked.forEach((charEl) => charEl.classList.add("is-drop-off"));
          }

          setTimeout(() => {
            clearDropClasses();
            applyRecoveryShift();
            scheduleRandomDrop();
          }, offMs);
        }, waitMs);
      };

      schedulePullShift();
      scheduleSpeedShift();
      scheduleRandomDrop();
      scheduleLetterGlowPulse();
      scheduleStaticSweep();
    }
  </script>

  <script>
    import "../scripts/wireframe-portrait-boot";
    import { playWormholeTransition } from "../scripts/wormhole-transition";

    const bindWormholeNav = () => {
      const wrap = document.querySelector(".glitch-name-wrap");
      if (!wrap || wrap.dataset.wormholeBound === "true") return;
      let lock = false;
      wrap.addEventListener("click", () => {
        if (lock) return;
        lock = true;
        const rect = wrap.getBoundingClientRect();
        playWormholeTransition(
          rect.left + rect.width / 2,
          rect.top + rect.height / 2,
          "/pocket-universe-x/"
        );
      });
      wrap.dataset.wormholeBound = "true";
    };

    bindWormholeNav();
    document.addEventListener("astro:page-load", bindWormholeNav);
  </script>
</BaseLayout>
