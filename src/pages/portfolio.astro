---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { recentPortfolioProjects } from "../data/portfolio";
---

<BaseLayout title="Portfolio" sideBarActiveItemID="portfolio">
  <div class="space-y-4 mb-5">
    <div class="text-3xl w-full font-bold">Portfolio</div>
    <p class="text-base-content/75 max-w-2xl">Selected recent work across research and personal builds.</p>
  </div>

  {
    recentPortfolioProjects.map((project, index) => (
      <>
        {index > 0 && <div class="divider my-0" />}
        <HorizontalCard
          title={project.title}
          img={project.img}
          desc={project.desc}
          url={project.url}
          badge={project.badge}
          target={project.target}
        />
      </>
    ))
  }

  <div class="mt-10 flex flex-wrap gap-3">
    <a href="/portfolio/research" class="btn btn-outline btn-sm">All research projects</a>
    <a href="/portfolio/personal" class="btn btn-outline btn-sm">All personal projects</a>
  </div>
</BaseLayout>
