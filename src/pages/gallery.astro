---
import BaseLayout from "../layouts/BaseLayout.astro";
import { galleryImages } from "../data/gallery";
---

<BaseLayout title="Gallery" sideBarActiveItemID="gallery">
  <div class="mb-8">
    <h1 class="text-3xl font-bold mb-2">Gallery</h1>
    <p class="text-base-content/75 max-w-2xl">Photos and image work. Add files to <code class="text-sm">public/gallery/</code> and update <code class="text-sm">src/data/gallery.ts</code>.</p>
  </div>

  <ul class="gallery-grid">
    {
      galleryImages.map((item) => (
        <li class:list={["gallery-grid__item", item.wide && "gallery-grid__item--wide"]}>
          <figure class="gallery-card">
            <a class="gallery-card__link" href={item.src} target="_blank" rel="noopener noreferrer">
              <img
                class="gallery-card__img"
                src={item.src}
                alt={item.alt}
                loading="lazy"
                decoding="async"
                width={item.wide ? 900 : 480}
                height={item.wide ? 520 : 480}
              />
            </a>
            {item.caption && <figcaption class="gallery-card__caption">{item.caption}</figcaption>}
          </figure>
        </li>
      ))
    }
  </ul>
</BaseLayout>
