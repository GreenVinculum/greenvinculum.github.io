---
const { title, subtitle, isCurrent = false } = Astro.props;
---

<article
  class="news-item timeline-reveal is-faded"
  data-current={isCurrent ? "true" : undefined}
>
  <div class="news-node" aria-hidden="true"></div>
  <div class="news-item__body">
    <h3 class="font-semibold mb-1">{title}</h3>
    <span class="font-light text-sm block opacity-80">{subtitle}</span>
    <div class="my-2 text-justify">
      <slot />
    </div>
  </div>
</article>
