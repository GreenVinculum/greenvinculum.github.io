---
const { sideBarActiveItemID } = Astro.props;
const activeClass = "bg-base-300"; // For primary color replace with `active` class
---

<ul class="menu grow shrink menu-md overflow-y-auto">
    <li><a class="py-3 text-base" id="home" href="/">Home</a></li>
    <li id="portfolioMenuItem" class="portfolio-menu-block">
        <a class="py-3 text-base grow" id="portfolio" href="/portfolio">Portfolio</a>
        <ul id="portfolioSubmenu" class="hidden">
            <li><a class="text-sm" id="portfolioResearch" href="/portfolio/research">Research</a></li>
            <li><a class="text-sm" id="portfolioPersonal" href="/portfolio/personal">Personal</a></li>
        </ul>
    </li>
    <li><a class="py-3 text-base" id="services" href="/services">Services</a></li>
    <li><a class="py-3 text-base" id="store" href="/store">Store</a></li>
    <li><a class="py-3 text-base" id="blog" href="/blog/">Blog</a></li>
    <li><a class="py-3 text-base" id="cv" href="/cv">CV</a></li>
    <li><a class="py-3 text-base" id="gallery" href="/gallery">Gallery</a></li>
    <li>
        <a
            class="py-3 text-base"
            href="mailto:cahn4@gmu.edu"
            target="_blank"
            referrerpolicy="no-referrer-when-downgrade">Contact</a
        >
    </li>
</ul>

<script define:vars={{ sideBarActiveItemID, activeClass }}>
const initSidebarMenu = () => {
    const activeItemElem = document.getElementById(sideBarActiveItemID);
    if (activeItemElem) {
        activeItemElem.classList.add(activeClass);
    }

    const portfolioMenu = document.getElementById("portfolioSubmenu");
    const portfolioLink = document.getElementById("portfolio");
    const portfolioIds = ["portfolio", "portfolioResearch", "portfolioPersonal"];
    const PORTFOLIO_MENU_KEY = "portfolioSubmenuOpen";
    if (portfolioMenu) {
        const shouldOpen = localStorage.getItem(PORTFOLIO_MENU_KEY) === "true" || portfolioIds.includes(sideBarActiveItemID);
        portfolioMenu.classList.toggle("hidden", !shouldOpen);
    }
    if (portfolioLink && portfolioMenu && portfolioLink.dataset.bound !== "true") {
        portfolioLink.addEventListener("click", (event) => {
            const onPortfolioHome = window.location.pathname === "/portfolio";
            if (onPortfolioHome) {
                event.preventDefault();
                portfolioMenu.classList.toggle("hidden");
                localStorage.setItem(PORTFOLIO_MENU_KEY, String(!portfolioMenu.classList.contains("hidden")));
            } else {
                portfolioMenu.classList.remove("hidden");
                localStorage.setItem(PORTFOLIO_MENU_KEY, "true");
            }
        });
        portfolioLink.dataset.bound = "true";
    }
};

initSidebarMenu();
document.addEventListener("astro:page-load", initSidebarMenu);
</script>
