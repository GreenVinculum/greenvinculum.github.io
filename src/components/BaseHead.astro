---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';

export interface Props {
	title: string;
	description: string;
	image?: string;
	ogType?: string;
	jsonLd?: Record<string, unknown> | string;
}

const { title, description, image = '/social_img.webp', ogType = 'website', jsonLd } = Astro.props;
const jsonLdString =
	typeof jsonLd === 'string' ? jsonLd : jsonLd ? JSON.stringify(jsonLd) : null;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="google-site-verification" content="0Mt9SH3wtgxY2tMpxD_snDilZ9LdYj1-M4yi4wgctbs" />
{Astro.url.pathname === "/" && (
  <>
    <link rel="preload" href="/data/wireframe-mesh.pck.gz" as="fetch" crossorigin fetchpriority="high" />
    <link rel="preload" href="/media/wireframe-poster.png" as="image" fetchpriority="high" />
    <script is:inline>
      if (!window.__wireframeMeshPrefetch) {
        window.__wireframeMeshPrefetch = fetch("/data/wireframe-mesh.pck.gz", { credentials: "same-origin" });
      }
    </script>
    <script>
      import { startWireframeMeshPrefetch } from "../lib/wireframe/wireframe-boot";
      startWireframeMeshPrefetch();
      void import("../lib/wireframe/WireframePortrait");
      void import("../lib/wireframe/WebGLWireframePortrait");
    </script>
  </>
)}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

{jsonLdString && <script type="application/ld+json" set:html={jsonLdString} />}
