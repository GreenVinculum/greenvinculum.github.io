---
import {
  booksRead,
  GENRE_COLORS,
  tallyReadLogSegments,
  tallyVisualMediaByGenre,
  type ReadLogSegment,
} from "../data/currentlyReading";

const proseTally = tallyReadLogSegments(booksRead, {
  includeIf: (entry) => !entry.genres.includes("Manga") && !entry.genres.includes("Graphic Novel"),
});

const visualTally = tallyVisualMediaByGenre(booksRead);

const segmentTotal = (segments: ReadLogSegment[]) =>
  segments.reduce((sum, { count }) => sum + count, 0);

const legendLabel = (segments: ReadLogSegment[]) =>
  segments.map(({ genre }) => genre).join(", ");

const proseTotal = segmentTotal(proseTally);
const visualTotal = segmentTotal(visualTally);
const hasAny = proseTotal + visualTotal > 0;
---

<section id="books-read-log" class="blog-read-log blog-read-log--page-bottom" aria-label="Read log">
  <p class="blog-now-label mb-3">Read log</p>

  {
    hasAny ? (
      <div class="blog-read-chart">
        <div class="blog-read-chart__columns">
          {
            proseTotal > 0 ? (
              <div class="blog-read-chart__group">
                <p class="blog-read-chart__group-label">Books</p>
                <div
                  class="blog-read-chart__stack"
                  role="img"
                  aria-label={`Books by genre: ${legendLabel(proseTally)}`}
                >
                  {proseTally.map(({ genre, count }) => (
                    <span
                      class="blog-read-chart__segment"
                      style={`flex-grow: ${count}; background: ${GENRE_COLORS[genre]}`}
                      title={genre}
                    />
                  ))}
                </div>
                <ul class="blog-read-chart__legend" aria-hidden="true">
                  {proseTally.map(({ genre }) => (
                    <li class="blog-read-chart__legend-item">
                      <span
                        class="blog-read-chart__swatch"
                        style={`background: ${GENRE_COLORS[genre]}`}
                      />
                      <span class="blog-read-chart__legend-label">{genre}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ) : null
          }

          {
            visualTotal > 0 ? (
              <div class="blog-read-chart__group">
                <p class="blog-read-chart__group-label">Manga / graphic novels</p>
                <div
                  class="blog-read-chart__stack"
                  role="img"
                  aria-label={`Manga and graphic novels by genre: ${legendLabel(visualTally)}`}
                >
                  {visualTally.map(({ genre, count }) => (
                    <span
                      class="blog-read-chart__segment"
                      style={`flex-grow: ${count}; background: ${GENRE_COLORS[genre]}`}
                      title={genre}
                    />
                  ))}
                </div>
                <ul class="blog-read-chart__legend" aria-hidden="true">
                  {visualTally.map(({ genre }) => (
                    <li class="blog-read-chart__legend-item">
                      <span
                        class="blog-read-chart__swatch"
                        style={`background: ${GENRE_COLORS[genre]}`}
                      />
                      <span class="blog-read-chart__legend-label">{genre}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ) : null
          }
        </div>
      </div>
    ) : (
      <p class="blog-read-log__empty text-sm text-base-content/70">
        Add finished books to <code class="text-xs">src/data/books-read.json</code> — each entry
        needs <code class="text-xs">title</code>, <code class="text-xs">author</code>, and
        <code class="text-xs">genres</code>.
      </p>
    )
  }
</section>
