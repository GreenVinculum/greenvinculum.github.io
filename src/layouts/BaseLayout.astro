---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SideBar from "../components/SideBar.astro";
import { ViewTransitions } from "astro:transitions";

import { SITE_TITLE, SITE_DESCRIPTION, TRANSITION_API } from "../config";
import { THEMES, THEME_STORAGE_KEY, VHS_STYLES } from "../scripts/theme-preference";

const {
  image,
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  jsonLd,
  includeSidebar = true,
  hideHeader = false,
  noindex = false,
  sideBarActiveItemID,
  ogType,
} = Astro.props;
---

<!doctype html>
<html lang="en" data-vhs-style="cinematic">
  <head>
    <script is:inline define:vars={{ THEME_STORAGE_KEY, THEMES, VHS_STYLES }}>
      (() => {
        const stored = localStorage.getItem(THEME_STORAGE_KEY);
        const theme =
          stored === THEMES.dark || stored === THEMES.light
            ? stored
            : window.matchMedia("(prefers-color-scheme: dark)").matches
              ? THEMES.dark
              : THEMES.light;
        const vhsStyle = VHS_STYLES[theme];
        document.documentElement.setAttribute("data-theme", theme);
        document.documentElement.setAttribute("data-vhs-style", vhsStyle);
        document.documentElement.style.colorScheme = theme === THEMES.dark ? "dark" : "light";
      })();
    </script>
    <script>
      import {
        attachThemeGlobals,
        initThemePreference,
        syncThemePreference,
      } from "../scripts/theme-preference";

      attachThemeGlobals();
      initThemePreference();
      document.addEventListener("astro:page-load", syncThemePreference);
    </script>
    <BaseHead title={title} description={description} image={image} ogType={ogType} jsonLd={jsonLd} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {TRANSITION_API && <ViewTransitions />}
  </head>
  <body>
    <div class="site-vhs-shell">
      <div aria-hidden="true" class="site-vhs-bg">
        <span class="site-vhs-layer site-vhs-layer-gradient"></span>
        <span class="site-vhs-layer site-vhs-layer-grid"></span>
        <span class="site-vhs-layer site-vhs-layer-noise"></span>
        <span class="site-vhs-layer site-vhs-layer-scan"></span>
        <span class="site-vhs-layer site-vhs-layer-vignette"></span>
      </div>

      <div class="site-vhs-content bg-base-100 drawer lg:drawer-open">
      <input id="my-drawer" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content bg-base-100">
        {!hideHeader && <Header title={SITE_TITLE} />}
        <div class="md:flex md:justify-center">
          <main class:list={["p-6 max-w-[100vw]", hideHeader ? "pt-6" : "pt-10 lg:max-w-[900px]"]}>
            <slot />
          </main>
        </div>
        <Footer />
      </div>
      {includeSidebar && <SideBar sideBarActiveItemID={sideBarActiveItemID} />}
    </div>
    </div>
  </body>
</html>
